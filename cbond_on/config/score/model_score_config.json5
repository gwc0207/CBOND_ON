{
  default_model_id: "lgbm_factor_MSE",
  model_id: "lgbm_factor_MSE",
  start: "2025-06-01",
  end: "2026-03-30",
  label_cutoff: null,
  execution: {
    // Refit cadence in trading-day steps (1 = refit every target day).
    refit_every_n_days: 1,
    // Number of training processes. model_score.py will auto split shards.
    train_processes: 8,
    // Threading controls applied in model_score_service (all model types).
    threading: {
      omp_num_threads: 12,
      mkl_num_threads: 12,
      openblas_num_threads: 1,
      numexpr_num_threads: 1,
      pyarrow_num_threads: 12,
      pyarrow_io_threads: 4
    }
  },
  models: {
    linear_factor_default: {
      model_type: "linear",
      model_config: "models/linear/linear_factor_default"
    },
    lgbm_factor_MSE: {
      model_type: "lgbm",
      model_config: "models/lgbm/lgbm_factor_MSE"
    },
    lgbm_factor_ranker: {
      model_type: "lgbm_ranker",
      model_config: "models/lgbm_ranker/lgbm_factor_ranker"
    },
    lob_st_default: {
      model_type: "lob",
      model_config: "models/lob/model"
    }
  }
}
