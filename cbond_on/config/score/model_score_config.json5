{
  default_model_id: "lob_st_default",
  model_id: "lob_st_default",
  start: "2025-06-01",
  end: "2026-03-30",
  label_cutoff: null,
  execution: {
    // Refit cadence in trading-day steps (1 = refit every target day).
    refit_every_n_days: 15,
    // Number of training processes (single GPU recommends 1~2).
    train_processes: 1,
    // CPU workers for rolling data preparation (window concat / dataset prep).
    prep_workers: 8,
    // How many rolling windows are prepared ahead of training.
    prefetch_windows: 4,
    // Threading controls applied in model_score runtime (all model types).
    threading: {
      omp_num_threads: 8,
      mkl_num_threads: 8,
      openblas_num_threads: 1,
      numexpr_num_threads: 1,
      pyarrow_num_threads: 8,
      pyarrow_io_threads: 4
    },
    // Shared W&B config for all model runners.
    // Per-model config can override this with its own `wandb` block.
    wandb: {
      enabled: false,
      project: "cbond_on",
      entity: null,
      mode: "online", // online | offline | disabled
      local_dir: {
        windows: "D:/cbond_on/results/wandb",
        linux: "/home/gswzif/cbond_on_runtime/results/wandb"
      },
      group: "model_score",
      job_type: "train",
      run_name: "", // empty => auto-generated
      tags: ["model_score"],
      save_code: false,
      log_iter_metrics: true,
      log_every_n_iter: 10,
      max_iter_points: 0 // 0 => no limit
    }
  },
  models: {
    linear_factor_default: {
      model_type: "linear",
      model_config: "models/linear/linear_factor_default"
    },
    lgbm_factor_MSE: {
      model_type: "lgbm",
      model_config: "models/lgbm/lgbm_factor_MSE"
    },
    lgbm_factor_ranker: {
      model_type: "lgbm_ranker",
      model_config: "models/lgbm_ranker/lgbm_factor_ranker"
    },
    lob_st_default: {
      model_type: "lob",
      model_config: "models/lob/model"
    }
  }
}
