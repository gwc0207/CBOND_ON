{
  // base model selector (must exist in score/model_score config models)
  base_model_id: "lgbm_factor_MSE",
  model_score_config: "score/model_score",
  factor_config: "factor",

  // test window
  start: "2025-06-01",
  end: "2026-03-30",
  // cross-section bins used in evaluation/reporting
  bins: 20,
  // rolling window for bin alpha significance t-stat
  alpha_significance_window: 40,

  // external factor lists
  baseline_factors_file: "score/factor_baseline_factors.json",
  blacklist_file: "score/factor_blacklist.json",

  // debug knob: 0 = all candidate extras
  // (candidate extras = expected factors - baseline factors - blacklist)
  max_candidates: 0,

  // forwarded into model_score.execution
  execution: {
    refit_every_n_days: 1,
    train_processes: 1
  },

  selection: {
    // currently supported: importance_topn
    mode: "importance_topn",
    // baseline_plus_candidates | baseline_only | candidates_only
    pool_source: "baseline_plus_candidates",
    // LightGBM importance type: gain | split
    importance_type: "gain",
    // keep top N after importance ranking (<=0 means keep all)
    top_n: 30,
    // drop factors with importance_mean < min_importance
    min_importance: 0.0,
    // plot top K bars in stage1_full_pool/feature_importance_topk.png
    plot_top_k: 30
  }
}
