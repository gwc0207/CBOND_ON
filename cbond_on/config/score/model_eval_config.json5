{
  // Experiment identity.
  experiment_name: "model_eval_v1",

  // Reuse model registry from model_score config.
  model_score_config: "score/model_score",
  model_id: "lgbm_factor_MSE",

  // Evaluation window (trading-day filtering follows existing score pipeline behavior).
  start: "2025-06-01",
  end: "2025-12-31",
  label_cutoff: null,

  // If true, run model_score first, then evaluate scores.
  run_model_before_eval: true,

  // Optional runtime override passed into model runners.
  execution: {
    refit_every_n_days: 1,
    score_guard: {
      enabled: true,
      warn_same_sign: false,
      fail_on_all_equal: false,
      fail_all_equal_days: 0,
      // Sweep guard: if a trial cannot split a day into enough bins, fail that trial.
      bin_guard_enabled: true,
      required_bins: 20,
      bin_guard_min_samples: 20,
      fail_on_insufficient_bins: true,
      fail_insufficient_bins_days: 0
    }
  },

  // Evaluation settings.
  eval: {
    bins: 20,
    objective: {
      metric: "rank_ic_mean",
      higher_is_better: true
    }
  },

  // Hyperparameter tuning settings.
  tuning: {
    enabled: true,
    search_type: "wandb_sweep", // grid | random | wandb_sweep
    max_trials: 16,
    random_seed: 42,
    // Used when search_type=wandb_sweep.
    // Parameter space still uses the same dot-path keys.
    wandb: {
      project: "cbond_on_tuning",
      entity: "1094028578-kings-college-london",
      name: "", // empty => auto-generated
      method: "random", // random | grid | bayes
      count: 16, // number of sweep trials to run locally
      mode: "online", // online | offline | disabled
      local_dir: "D:/cbond_on/results/wandb",
      group: "model_eval",
      job_type: "tuning",
      tags: ["model_eval", "sweep"],
      // Avoid nested W&B runs in model runners during sweep trial.
      disable_inner_model_wandb: true
    },
    parameter_space: {
      // Dot-path keys in model config.
      "lgbm_params.num_leaves": [16, 32, 63, 127, 255],
      "lgbm_params.max_depth": [4, 8, 12, 16, 20],
      "lgbm_params.reg_alpha": [0.001, 0.005, 0.01, 0.05, 0.1],
      "lgbm_params.reg_lambda": [0.001, 0.005, 0.01, 0.05, 0.1, 0.5, 1.0],
      "lgbm_params.learning_rate": [0.0003, 0.0005, 0.001],
      "lgbm_params.min_data_in_leaf": [20, 30, 50],
      "lgbm_params.subsample": [0.6, 0.7, 0.8, 0.9],
      "lgbm_params.colsample_bytree": [0.6, 0.7, 0.8, 0.9]
    }
  }
}
