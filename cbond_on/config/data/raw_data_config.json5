{
  start: "2025-06-01",
  end: "2026-03-03",
  refresh: false,
  overwrite: false,
  assets: ["cbond"],
  sync_snapshot: true,
  sync_kline: true,
  full_if_empty: true,
  mode: "both",
  source: {
    history: {
      nfs_required: true,
      db_optional: true
    },
    intraday: {
      type: "redis_snapshot",
      asset: "cbond",
      incremental: true
    }
  },
  data: {
    snapshot_root: {
      windows: "D:/cbond_data_hub/raw_data/snapshot/cbond/raw_data",
      linux: "/mnt/cbond_data_hub_ro/raw_data/snapshot/cbond/raw_data"
    },
    snapshot_interval_seconds: 3,
    orderbook_levels: 5,
    price_field: "last",
    drop_no_trade: true,
    use_prev_snapshot: true
  },
  db: {
    sync_tables: [
      "metadata.trading_calendar",
      "market_cbond.daily_price",
      "market_cbond.daily_twap",
      "market_cbond.daily_vwap",
      "market_cbond.daily_deriv",
      "market_cbond.daily_base",
      "market_cbond.daily_rating"
    ]
  },
  nfs: {
    nfs_root: "\\\\nfs\\999.999@10.1.30.100\\data",
    base_dir: "yinhe-data/snapshot/cbond/raw_data"
  }
}
