{
  start: "2025-01-03",
  end: "2025-01-03",
  panel_name: "T1430",
  factor_time: "14:30",
  label_time: "14:42",
  refresh: true,
  overwrite: false,
  workers: 1,
  factor_workers: 2,
  compute: {
    engine: "rust", // rust | rust_shm_exp | python (no automatic fallback)
    backend: "cpu",       // auto | torch | cpu
    torch_device: "cuda", // e.g. "cuda", "cuda:0"
    fallback_cpu: true,
    dataframe_backend: "pandas", // auto | cudf | pandas
    fallback_pandas: true,
    // used by engine=rust_shm_exp
    shm_mp_start_method: "auto", // auto=>linux:fork, windows:spawn
    shm_fallback_to_rust: true,
    // used by rust/rust_shm_exp unified planning
    plan_max_windows: 8,
    plan_max_levels: 8,
    plan_max_time_ranges: 8,
    plan_log_summary: true,
    debug_log_each_record: false
  },
  factor_files: [
    "factor/lgbm_factor_MSE.json5"
  ],
  context: {
    stock_panel: { enabled: false, strict: false },
    bond_stock_map: { enabled: false, strict: false }
  },
  backtest_enabled: false,
  factors: [],
  backtest: {
    workers: 6,
    min_count: 10,
    ic_bins: 20,
    bin_count: 20,
    bin_select: null,
    bin_source: "auto",
    bin_top_k: 2,
    bin_lookback_days: 10
  },
  screening: {
    enabled: true,
    ic_metric: "rank_ic_mean",
    ir_metric: "rank_ic_ir",
    ic_abs_min: 0.015,
    ir_abs_min: 0.15,
    sharpe_min: 0.3,
    copy_reports: true
  }
}
