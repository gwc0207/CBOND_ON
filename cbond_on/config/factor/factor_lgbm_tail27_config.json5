  refresh: false,
  overwrite: false,
  workers: 8,
  factor_workers: 1,
  backtest_enabled: false,

  factor_files: [
    "factor/packs/live_screened_no_winsor_27.json5",
  ],
  factors: [],

  tail_features: {
    enabled: true,
    groupby: "dt",
