    { name: "ret_5m", factor: "ret_window", params: { window_minutes: 5, price_col: "last" } },
    { name: "ret_10m", factor: "ret_window", params: { window_minutes: 10, price_col: "last" } },
    { name: "ret_30m", factor: "ret_window", params: { window_minutes: 30, price_col: "last" } },
    { name: "ret_60m", factor: "ret_window", params: { window_minutes: 60, price_col: "last" } },
