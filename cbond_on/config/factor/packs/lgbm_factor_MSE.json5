    { name: "volume_30m", factor: "volume_sum", params: { window_minutes: 30, volume_col: "volume" } },
    { name: "amount_30m", factor: "amount_sum", params: { window_minutes: 30, amount_col: "amount" } },
    { name: "vwap_30m", factor: "vwap", params: { window_minutes: 30, volume_col: "volume", amount_col: "amount" } },
    { name: "volimb_30m_l3", factor: "volume_imbalance", params: { window_minutes: 30, levels: 3 } },
    { name: "spread", factor: "spread", params: { bid_col: "bid_price1", ask_col: "ask_price1" } },
    { name: "depth_imb_l3", factor: "depth_imbalance", params: { levels: 3 } },
    { name: "mid_move_30m", factor: "midprice_move", params: { window_minutes: 30, bid_col: "bid_price1", ask_col: "ask_price1" } },
    { name: "turnover_30m", factor: "turnover_rate", params: { window_minutes: 30, volume_col: "volume", shares_col: "num_trades" } },
