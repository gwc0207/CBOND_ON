    { name: "depth_slope_l5", factor: "depth_slope", params: { levels: 5 } },
    { name: "ret_skew_30m", factor: "return_skew", params: { window_minutes: 30, price_col: "last", use_log_return: true } },
    { name: "vwap_gap_30m", factor: "vwap_gap", params: { window_minutes: 30, price_col: "last", volume_col: "volume", amount_col: "amount" } }
