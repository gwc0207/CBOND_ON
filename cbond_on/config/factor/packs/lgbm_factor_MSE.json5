    { name: "mom_slope_30m", factor: "mom_slope", params: { window_minutes: 30, price_col: "last" } },
    { name: "vol_30m", factor: "volatility", params: { window_minutes: 30, price_col: "last", use_log_return: true } },
    { name: "vol_60m", factor: "volatility", params: { window_minutes: 60, price_col: "last", use_log_return: true } },
    { name: "range_30m", factor: "range_ratio", params: { window_minutes: 30, price_col: "last" } },
