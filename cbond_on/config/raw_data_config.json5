{
  start: "2026-02-20",
  end: "2026-02-24",
  refresh: false,
  overwrite: true,
  sync_snapshot: true,
  sync_kline: true,
  full_if_empty: true,
  mode: "both",
  data: {
    snapshot_root: "D:/cbond_on/raw_data/snapshot/cbond/raw_data",
    snapshot_interval_seconds: 3,
    orderbook_levels: 5,
    price_field: "last",
    filter_trading_phase: true,
    allowed_phases: ["T"],
    drop_no_trade: true,
    use_prev_snapshot: true
  },
  db: {
    sync_tables: [
      "metadata.trading_calendar",
      "market_cbond.daily_price",
      "market_cbond.daily_twap",
      "market_cbond.daily_vwap",
      "market_cbond.daily_deriv",
      "market_cbond.daily_base",
      "market_cbond.daily_rating"
    ]
  },
  nfs: {
    nfs_root: "\\\\nfs\\999.999@10.1.30.100\\data",
    base_dir: "yinhe-data/snapshot/cbond/raw_data"
  }
